# Modify the following line to update Dremio version
# Do not forget `-SNAPSHOT` qualifier
# e.g `-Drevision=99.98.97-SNAPSHOT`
-Drevision=26.0.5-202509091642240013-f5051a07
# Local repo inside the workspace (avoids permission issues with /root/.m2; path is relative to cwd)
-Dmaven.repo.local=.m2/repository
